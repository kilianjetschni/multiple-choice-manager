@model Exam
@{
    ViewData["Title"] = $"Prüfung – {Model.Course!.Title}";
}

<nav aria-label="breadcrumb" class="d-print-none">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Prüfungen</a></li>
        <li class="breadcrumb-item active" aria-current="page">
            @Model.Course!.Title – @Model.Date.ToString("dd.MM.yyyy")
        </li>
    </ol>
</nav>

<div class="mc-page-header">
    <div>
        <span class="mc-eyebrow d-block mb-2">Prüfung</span>
        <h1>@Model.Course!.Title</h1>
        <p class="mc-page-subtitle">Datum: @Model.Date.ToString("dd.MM.yyyy") — @Model.Questions.Count Fragen</p>
    </div>
    <div class="mc-page-header-actions d-print-none">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="bi bi-pencil me-1"></i>Bearbeiten
        </a>
        <button type="button" class="btn btn-outline-primary" onclick="window.print()">
            <i class="bi bi-printer me-1"></i>Drucken
        </button>
    </div>
</div>

<p class="text-body-secondary d-print-none mb-4">
    <i class="bi bi-check-circle-fill text-success me-1"></i>
    markiert die richtige Antwort; beim Drucken wird die Markierung ausgeblendet.
</p>

<div class="card">
    <div class="card-body">
        @{
            var questionNumber = 1;
        }
        @foreach (var question in Model.Questions)
        {
            <article class="mb-4 pb-3 @(questionNumber <= Model.Questions.Count - 1 ? "border-bottom" : null)">
                <p class="fw-semibold text-body-emphasis mb-3">
                    @(questionNumber++). @question.Text
                </p>
                <div class="d-flex flex-column gap-2 ms-1">
                    @for (var i = 0; i < question.AnswerOptions.Count; i++)
                    {
                        var option = question.AnswerOptions[i];
                        <div class="d-flex align-items-center gap-3">
                            <span class="mc-answer-letter">@((char)('A' + i))</span>
                            <span>@option.Text</span>
                            @if (option.IsCorrect)
                            {
                                <span class="mc-answer-badge d-print-none">
                                    <i class="bi bi-check-lg"></i>Richtig
                                </span>
                            }
                        </div>
                    }
                </div>
            </article>
        }
    </div>
</div>

<div class="d-print-none mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Zurück zur Übersicht
    </a>
</div>
