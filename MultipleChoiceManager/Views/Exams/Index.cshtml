@model List<CourseExamsViewModel>
@{
    ViewData["Title"] = "Prüfungen";
}

<h1 class="h2 mb-4">Prüfungen</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        Noch keine Lehrveranstaltungen vorhanden. Bitte zuerst eine Lehrveranstaltung anlegen.
    </div>
}

@foreach (var course in Model)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-0">@course.CourseTitle</h2>
                <small class="text-muted">
                    @course.AvailableQuestionCount Fragen aus allen Kapiteln hinterlegt
                </small>
            </div>
            @if (course.AvailableQuestionCount == 0)
            {
                <button type="button" class="btn btn-primary" disabled
                        title="In dieser Veranstaltung sind noch keine Fragen hinterlegt.">
                    <i class="bi bi-plus-lg me-1"></i>Neue Prüfung erstellen
                </button>
            }
            else
            {
                <a asp-action="Create" asp-route-courseId="@course.CourseId" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Neue Prüfung erstellen
                </a>
            }
        </div>
        <div class="card-body">
            @if (course.Exams.Count == 0)
            {
                <p class="text-muted mb-0">Noch keine Prüfungen vorhanden.</p>
            }
            else
            {
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Datum</th>
                            <th>Fragen</th>
                            <th class="text-end">Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exam in course.Exams)
                        {
                            <tr>
                                <td>@exam.Date.ToString("dd.MM.yyyy")</td>
                                <td>@exam.QuestionCount</td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@exam.Id"
                                       class="btn btn-sm btn-outline-primary" title="Einsehen">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Löschen"
                                            data-bs-toggle="modal" data-bs-target="#deleteModal-@exam.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@foreach (var course in Model)
{
    foreach (var exam in course.Exams)
    {
        <div class="modal fade" id="deleteModal-@exam.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Prüfung löschen</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                    </div>
                    <div class="modal-body">
                        <p>
                            Soll die Prüfung vom <strong>@exam.Date.ToString("dd.MM.yyyy")</strong>
                            (@course.CourseTitle) wirklich gelöscht werden?
                        </p>
                        <p class="text-muted mb-0">Die Fragen selbst bleiben erhalten.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <form asp-action="Delete" asp-route-id="@exam.Id" method="post">
                            <button type="submit" class="btn btn-danger">Löschen</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
