@model ExamFormViewModel
@{
    ViewData["Title"] = "Neue Prüfung";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Prüfungen</a></li>
        <li class="breadcrumb-item active" aria-current="page">Neue Prüfung</li>
    </ol>
</nav>

<h1 class="h2 mb-1">Neue Prüfung</h1>
<p class="text-muted mb-4">Lehrveranstaltung: @Model.CourseTitle</p>

<div class="col-lg-8">
    @if (Model.ShowAvailabilityWarning)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-1"></i>
            Es sind in dieser Veranstaltung nur <strong>@Model.AvailableQuestionCount</strong> Fragen
            hinterlegt, Sie möchten aber <strong>@Model.QuestionCount</strong> Fragen generieren.
            Möchten Sie trotzdem mit @Model.AvailableQuestionCount Fragen fortfahren?
        </div>
    }

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="CourseId" />

        <div class="mb-3">
            <label asp-for="Date" class="form-label"></label>
            <input asp-for="Date" class="form-control" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="QuestionCount" class="form-label"></label>
            <input asp-for="QuestionCount" class="form-control" type="number" min="1" placeholder="z. B. 10" />
            <div class="form-text">
                Die Fragen werden zufällig und ohne Duplikate aus allen Kapiteln der Veranstaltung
                ausgewählt (@Model.AvailableQuestionCount verfügbar).
            </div>
            <span asp-validation-for="QuestionCount" class="text-danger"></span>
        </div>

        @if (Model.ShowAvailabilityWarning)
        {
            <button type="submit" name="ProceedWithAvailable" value="true" class="btn btn-warning">
                Mit @Model.AvailableQuestionCount Fragen fortfahren
            </button>
        }
        <button type="submit" class="btn btn-primary">Erstellen</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Abbrechen</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
