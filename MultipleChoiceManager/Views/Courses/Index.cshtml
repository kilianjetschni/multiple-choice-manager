@model List<CourseListItemViewModel>
@{
    ViewData["Title"] = "Lehrveranstaltungen";
}

<div class="mc-page-header">
    <div>
        <span class="mc-eyebrow d-block mb-2">Katalog</span>
        <h1>Lehrveranstaltungen</h1>
        <p class="mc-page-subtitle">Struktur, Kapitel und Fragenkataloge Ihrer Kurse verwalten.</p>
    </div>
    <div class="mc-page-header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Neue Lehrveranstaltung
        </a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="mc-empty-state">
        <div class="mc-empty-icon">
            <i class="bi bi-mortarboard"></i>
        </div>
        <h2 class="h4">Noch keine Lehrveranstaltungen</h2>
        <p>Legen Sie Ihre erste Lehrveranstaltung an, um Kapitel und Fragen zu pflegen.</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Neue Lehrveranstaltung
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-lg-2 g-3">
        @foreach (var course in Model)
        {
            <div class="col">
                <div class="card card-hoverable h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                            <h2 class="h4 mb-0">@course.Title</h2>
                            @if (course.Level == CourseLevel.Master)
                            {
                                <span class="badge text-bg-primary flex-shrink-0">@course.Level</span>
                            }
                            else
                            {
                                <span class="badge mc-badge-outline flex-shrink-0">@course.Level</span>
                            }
                        </div>

                        <p class="d-flex align-items-center gap-2 text-body-secondary mb-3">
                            <i class="bi bi-person"></i>
                            <span>@course.LecturerName</span>
                        </p>

                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <a asp-controller="Chapters" asp-action="Index" asp-route-courseId="@course.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-collection me-1"></i>Kapitel
                                <span class="badge text-bg-primary rounded-pill ms-1">@course.ChapterCount</span>
                            </a>
                            <a asp-controller="Exams" asp-action="Index" asp-fragment="course-@course.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-journal-check me-1"></i>Prüfungen
                                <span class="badge text-bg-primary rounded-pill ms-1">@course.ExamCount</span>
                            </a>
                            <div class="ms-auto d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@course.Id"
                                   class="btn btn-sm btn-outline-secondary btn-icon"
                                   title="Bearbeiten" aria-label="Bearbeiten">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-icon"
                                        title="Löschen" aria-label="Löschen"
                                        data-bs-toggle="modal" data-bs-target="#deleteModal-@course.Id">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @foreach (var course in Model)
    {
        <div class="modal fade" id="deleteModal-@course.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Lehrveranstaltung löschen</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-3">
                            Soll die Lehrveranstaltung <strong>@course.Title</strong> wirklich gelöscht werden?
                        </p>
                        <div class="alert alert-danger mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Alle zugehörigen Kapitel, Fragen und Prüfungen werden ebenfalls gelöscht.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <form asp-action="Delete" asp-route-id="@course.Id" method="post" class="m-0">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>Löschen
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}