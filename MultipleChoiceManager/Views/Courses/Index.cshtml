@model List<CourseListItemViewModel>
@{
    ViewData["Title"] = "Lehrveranstaltungen";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2 mb-0">Lehrveranstaltungen</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Neue Lehrveranstaltung
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Noch keine Lehrveranstaltungen vorhanden.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Titel</th>
                <th>Dozentenname</th>
                <th>Niveau</th>
                <th>Kapitel</th>
                <th class="text-end">Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td>@course.Title</td>
                    <td>@course.LecturerName</td>
                    <td>@course.Level</td>
                    <td>
                        <a asp-controller="Chapters" asp-action="Index" asp-route-courseId="@course.Id"
                           class="btn btn-sm btn-outline-primary">
                            Kapitel <span class="badge text-bg-primary">@course.ChapterCount</span>
                        </a>
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-secondary"
                           title="Bearbeiten">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-danger" title="Löschen"
                                data-bs-toggle="modal" data-bs-target="#deleteModal-@course.Id">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @foreach (var course in Model)
    {
        <div class="modal fade" id="deleteModal-@course.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Lehrveranstaltung löschen</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                    </div>
                    <div class="modal-body">
                        <p>Soll die Lehrveranstaltung <strong>@course.Title</strong> wirklich gelöscht werden?</p>
                        <p class="text-danger mb-0">
                            Alle zugehörigen Kapitel, Fragen und Prüfungen werden ebenfalls gelöscht.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <form asp-action="Delete" asp-route-id="@course.Id" method="post">
                            <button type="submit" class="btn btn-danger">Löschen</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
