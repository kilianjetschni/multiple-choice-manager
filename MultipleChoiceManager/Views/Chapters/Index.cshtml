@model Course
@{
    ViewData["Title"] = $"Kapitel – {Model.Title}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Courses" asp-action="Index">Lehrveranstaltungen</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
    </ol>
</nav>

<div class="card mb-4">
    <div class="card-body">
        <h1 class="h4 card-title mb-3">@Model.Title</h1>
        <dl class="row mb-0">
            <dt class="col-sm-3">Dozentenname</dt>
            <dd class="col-sm-9">@Model.LecturerName</dd>
            <dt class="col-sm-3">Niveau</dt>
            <dd class="col-sm-9">@Model.Level</dd>
        </dl>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 mb-0">Kapitel</h2>
    <a asp-action="Create" asp-route-courseId="@Model.Id" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Neues Kapitel
    </a>
</div>

@if (Model.Chapters.Count == 0)
{
    <div class="alert alert-info">Noch keine Kapitel vorhanden.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Nr.</th>
                <th>Titel</th>
                <th>Vorlesungsfolien</th>
                <th class="text-end">Aktionen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var chapter in Model.Chapters)
            {
                <tr>
                    <td>@chapter.ChapterNumber</td>
                    <td>@chapter.Title</td>
                    <td>
                        @if (chapter.SlidesBlobUrl is not null)
                        {
                            <a href="@chapter.SlidesBlobUrl" target="_blank" rel="noopener">
                                <i class="bi bi-file-earmark-pdf me-1"></i>Folien (PDF)
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@chapter.Id" class="btn btn-sm btn-outline-secondary"
                           title="Bearbeiten">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-danger" title="Löschen"
                                data-bs-toggle="modal" data-bs-target="#deleteModal-@chapter.Id">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @foreach (var chapter in Model.Chapters)
    {
        <div class="modal fade" id="deleteModal-@chapter.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Kapitel löschen</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                    </div>
                    <div class="modal-body">
                        <p>Soll das Kapitel <strong>@chapter.ChapterNumber. @chapter.Title</strong> wirklich gelöscht werden?</p>
                        <p class="text-danger mb-0">
                            Alle zugehörigen Fragen und Antwortoptionen werden ebenfalls gelöscht.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <form asp-action="Delete" asp-route-id="@chapter.Id" method="post">
                            <button type="submit" class="btn btn-danger">Löschen</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
