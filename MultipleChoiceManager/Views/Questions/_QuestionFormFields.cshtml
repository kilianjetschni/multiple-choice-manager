@model QuestionFormViewModel

<div class="mb-3">
    <label asp-for="Text" class="form-label"></label>
    <textarea asp-for="Text" class="form-control" rows="3"></textarea>
    <span asp-validation-for="Text" class="text-danger"></span>
</div>

<fieldset class="mb-3">
    <legend class="form-label fs-6 fw-semibold">
        Antwortoptionen <span class="text-muted fw-normal">(genau eine als richtig markieren)</span>
    </legend>
    @for (var i = 0; i < Model.Options.Count; i++)
    {
        <div class="mb-2">
            <div class="input-group">
                <div class="input-group-text">
                    <input type="radio" class="form-check-input mt-0" asp-for="CorrectOptionIndex"
                           value="@i" id="CorrectOptionIndex-@i"
                           aria-label="Antwortoption @(i + 1) als richtig markieren"
                           title="Als richtige Antwort markieren" />
                </div>
                <input type="hidden" asp-for="Options[i].Id" />
                <input asp-for="Options[i].Text" class="form-control" placeholder="Antwortoption @(i + 1)"
                       aria-label="Text der Antwortoption @(i + 1)" />
            </div>
            <span asp-validation-for="Options[i].Text" class="text-danger"></span>
        </div>
    }
    <span asp-validation-for="CorrectOptionIndex" class="text-danger"></span>
</fieldset>
