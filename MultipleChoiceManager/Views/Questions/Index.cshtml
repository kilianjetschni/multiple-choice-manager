@using System.Text.Json
@using MultipleChoiceManager.Services.Ai
@model Chapter
@{
    ViewData["Title"] = $"Fragen – {Model.Title}";
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    var proposalJson = TempData["AiQuestionProposal"] as string;
    var autoOpenReviewQuestionId = TempData["AiReviewQuestionId"] as string;
    AiQuestionProposalViewModel? questionProposal = null;

    if (!string.IsNullOrWhiteSpace(proposalJson))
    {
        try
        {
            questionProposal = JsonSerializer.Deserialize<AiQuestionProposalViewModel>(proposalJson, jsonOptions);
        }
        catch (JsonException)
        {
            questionProposal = null;
        }
    }
}

<div id="aiPageContent">
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Courses" asp-action="Index">Lehrveranstaltungen</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Chapters" asp-action="Index" asp-route-courseId="@Model.CourseId">@Model.Course!.Title</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">@Model.ChapterNumber. @Model.Title</li>
    </ol>
</nav>

<div class="mc-page-header">
    <div>
        <span class="mc-eyebrow d-block mb-2">Fragenkatalog</span>
        <h1>Fragen</h1>
        <p class="mc-page-subtitle">Kapitel @Model.ChapterNumber: @Model.Title — @Model.Course!.Title</p>
    </div>
    <div class="mc-page-header-actions">
        <form asp-action="Generate" method="post" class="m-0"
              data-ai-busy-form
              data-ai-busy-title="KI erstellt einen Fragenvorschlag"
              data-ai-busy-message="Die PDF wird analysiert.">
            <input type="hidden" name="chapterId" value="@Model.Id" />
            <button type="submit" class="btn btn-success" disabled="@string.IsNullOrWhiteSpace(Model.SlidesBlobUrl)">
                <i class="bi bi-stars me-1"></i>Neue Frage generieren
            </button>
        </form>
        <a asp-action="Create" asp-route-chapterId="@Model.Id" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Neue Frage
        </a>
    </div>
</div>

@if (TempData["AiSuccess"] is string successMessage)
{
    <div class="alert alert-success" role="alert">
        <i class="bi bi-check-circle me-1"></i>@successMessage
    </div>
}

@if (TempData["AiError"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert" data-transient-error-alert>
        <i class="bi bi-exclamation-triangle me-1"></i>@errorMessage
    </div>
}

@if (string.IsNullOrWhiteSpace(Model.SlidesBlobUrl))
{
    <div class="alert alert-secondary" role="alert">
        <i class="bi bi-info-circle me-1"></i>
        Für dieses Kapitel ist keine PDF-Datei hinterlegt. Die KI-Generierung ist deshalb deaktiviert.
    </div>
}

@if (Model.Questions.Count == 0)
{
    <div class="mc-empty-state">
        <div class="mc-empty-icon">
            <i class="bi bi-patch-question"></i>
        </div>
        <h2 class="h4">Noch keine Fragen</h2>
        <p>Erfassen Sie eine neue Frage oder lassen Sie mit KI eine aus den Folien generieren.</p>
        <a asp-action="Create" asp-route-chapterId="@Model.Id" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Neue Frage
        </a>
    </div>
}
else
{
    @foreach (var question in Model.Questions)
    {
        <div class="mc-question-card">
            <div class="mc-question-header">
                <p class="mc-question-text">@question.Text</p>
            </div>
            @for (var i = 0; i < question.AnswerOptions.Count; i++)
            {
                var option = question.AnswerOptions[i];
                <div class="mc-answer-row @(option.IsCorrect ? "is-correct" : null)">
                    <span class="mc-answer-letter">@((char)('A' + i))</span>
                    <span class="mc-answer-text">@option.Text</span>
                    @if (option.IsCorrect)
                    {
                        <span class="mc-answer-badge">
                            <i class="bi bi-check-lg"></i>Richtig
                        </span>
                    }
                </div>
            }
            <div class="mc-question-actions">
                @if (!string.IsNullOrWhiteSpace(question.AiReviewResultJson))
                {
                    <button type="button" class="btn btn-sm btn-outline-success"
                            data-bs-toggle="modal" data-bs-target="#aiReviewModal-@question.Id">
                        <i class="bi bi-eye me-1"></i>Prüfung anzeigen
                    </button>
                }
                <form asp-action="Review" asp-route-id="@question.Id" method="post" class="m-0"
                      data-ai-busy-form
                      data-ai-busy-title="KI prüft die Frage"
                      data-ai-busy-message="Frage und Antwortoptionen werden geprüft.">
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-check2-circle me-1"></i>@(string.IsNullOrWhiteSpace(question.AiReviewResultJson) ? "Prüfen" : "Neu prüfen")
                    </button>
                </form>
                <a asp-action="Edit" asp-route-id="@question.Id" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-pencil me-1"></i>Bearbeiten
                </a>
                <button type="button" class="btn btn-sm btn-outline-danger"
                        data-bs-toggle="modal" data-bs-target="#deleteModal-@question.Id">
                    <i class="bi bi-trash me-1"></i>Löschen
                </button>
            </div>
        </div>
    }

    @foreach (var question in Model.Questions)
    {
        <div class="modal fade" id="deleteModal-@question.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Frage löschen</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-3">Soll die Frage <strong>@question.Text</strong> wirklich gelöscht werden?</p>
                        <div class="alert alert-danger mb-0">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Alle Antwortoptionen werden mitgelöscht; die Frage wird auch aus gespeicherten Prüfungen entfernt.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <form asp-action="Delete" asp-route-id="@question.Id" method="post" class="m-0">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>Löschen
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    @foreach (var question in Model.Questions.Where(q => !string.IsNullOrWhiteSpace(q.AiReviewResultJson)))
    {
        QuestionReviewResultDto? savedReviewResult = null;

        try
        {
            savedReviewResult = JsonSerializer.Deserialize<QuestionReviewResultDto>(question.AiReviewResultJson!, jsonOptions);
        }
        catch (JsonException)
        {
            savedReviewResult = null;
        }

        if (savedReviewResult is null)
        {
            continue;
        }

        <div class="modal fade" id="aiReviewModal-@question.Id" tabindex="-1" aria-labelledby="aiReviewModalLabel-@question.Id" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <div>
                            <span class="mc-eyebrow d-block mb-1">KI-Prüfung</span>
                            <h2 class="modal-title fs-5" id="aiReviewModalLabel-@question.Id">
                                @if (savedReviewResult.HasCriticalIssues)
                                {
                                    <span class="text-warning">
                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>@savedReviewResult.OverallVerdict
                                    </span>
                                }
                                else
                                {
                                    <span class="text-success">
                                        <i class="bi bi-check-circle-fill me-1"></i>@savedReviewResult.OverallVerdict
                                    </span>
                                }
                            </h2>
                            @if (question.AiReviewedAtUtc is not null)
                            {
                                <p class="text-muted small mb-0 mt-1">
                                    Geprüft am @question.AiReviewedAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") Uhr
                                </p>
                            }
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                    </div>
                    <div class="modal-body">
                        <p class="lead fs-6 mb-4">@savedReviewResult.Summary</p>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <section class="ai-review-panel">
                                    <h3 class="text-success">
                                        <i class="bi bi-check2-circle me-1"></i>Stärken
                                    </h3>
                                    @if (savedReviewResult.Strengths.Count == 0)
                                    {
                                        <p class="text-muted mb-0">Keine besonderen Stärken genannt.</p>
                                    }
                                    else
                                    {
                                        <ul class="mb-0 ps-3">
                                            @foreach (var strength in savedReviewResult.Strengths)
                                            {
                                                <li>@strength</li>
                                            }
                                        </ul>
                                    }
                                </section>
                            </div>
                            <div class="col-md-4">
                                <section class="ai-review-panel">
                                    <h3 class="text-warning">
                                        <i class="bi bi-exclamation-triangle me-1"></i>Auffälligkeiten
                                    </h3>
                                    @if (savedReviewResult.Issues.Count == 0)
                                    {
                                        <p class="text-muted mb-0">Keine Auffälligkeiten erkannt.</p>
                                    }
                                    else
                                    {
                                        <ul class="mb-0 ps-3">
                                            @foreach (var issue in savedReviewResult.Issues)
                                            {
                                                <li>@issue</li>
                                            }
                                        </ul>
                                    }
                                </section>
                            </div>
                            <div class="col-md-4">
                                <section class="ai-review-panel">
                                    <h3 class="text-primary">
                                        <i class="bi bi-tools me-1"></i>Vorschläge
                                    </h3>
                                    @if (savedReviewResult.Suggestions.Count == 0)
                                    {
                                        <p class="text-muted mb-0">Keine Änderungsvorschläge.</p>
                                    }
                                    else
                                    {
                                        <ul class="mb-0 ps-3">
                                            @foreach (var suggestion in savedReviewResult.Suggestions)
                                            {
                                                <li>@suggestion</li>
                                            }
                                        </ul>
                                    }
                                </section>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <a asp-action="Edit" asp-route-id="@question.Id" class="btn btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Frage bearbeiten
                        </a>
                        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Schließen</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@if (questionProposal is not null)
{
    var selectedCorrectOptionIndex = questionProposal.CorrectOptionIndex
        ?? questionProposal.Options.FindIndex(option => option.IsCorrect);

    <div class="modal fade" id="aiProposalModal" tabindex="-1" aria-labelledby="aiProposalModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
            <form asp-action="ConfirmGenerated" method="post" class="modal-content">
                <input type="hidden" name="ChapterId" value="@questionProposal.ChapterId" />
                <div class="modal-header">
                    <div>
                        <span class="mc-eyebrow d-block mb-1">
                            <i class="bi bi-stars me-1"></i>KI-Vorschlag
                        </span>
                        <h2 class="modal-title fs-5" id="aiProposalModalLabel">Neue Frage prüfen und bearbeiten</h2>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">
                        Die Frage wurde noch nicht gespeichert. Du kannst den Vorschlag hier anpassen und danach übernehmen.
                    </p>

                    <div class="mb-3">
                        <label for="aiQuestionText" class="form-label">Fragentext</label>
                        <textarea id="aiQuestionText"
                                  name="QuestionText"
                                  class="form-control"
                                  rows="3"
                                  maxlength="1000"
                                  required>@questionProposal.QuestionText</textarea>
                    </div>

                    <fieldset>
                        <legend class="form-label">Antwortoptionen</legend>
                        <div class="d-flex flex-column gap-2">
                            @for (var i = 0; i < questionProposal.Options.Count; i++)
                            {
                                var option = questionProposal.Options[i];
                                <div class="mc-answer-editor">
                                    <span class="mc-answer-letter">@((char)('A' + i))</span>
                                    <div class="form-check m-0 mc-answer-editor-radio">
                                        <input id="aiCorrectOption-@i"
                                               class="form-check-input"
                                               type="radio"
                                               name="CorrectOptionIndex"
                                               value="@i"
                                               required
                                               checked="@(selectedCorrectOptionIndex == i)" />
                                        <label class="form-check-label visually-hidden" for="aiCorrectOption-@i">
                                            Antwort @(i + 1) als richtig markieren
                                        </label>
                                    </div>
                                    <input type="text"
                                           name="Options[@i].Text"
                                           value="@option.Text"
                                           class="form-control"
                                           maxlength="500"
                                           aria-label="Text der Antwortoption @(i + 1)"
                                           required />
                                </div>
                            }
                        </div>
                        <div class="form-text mt-2">Radio-Button auswählen, um die richtige Antwort zu markieren.</div>
                    </fieldset>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Verwerfen</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>Frage speichern
                    </button>
                </div>
            </form>
        </div>
    </div>
}

</div>

<div id="aiBusyOverlay"
     class="ai-busy-overlay position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center text-white"
     role="status"
     aria-live="polite"
     aria-modal="true"
     tabindex="-1">
    <div class="text-center px-4">
        <div class="spinner-border mb-3" aria-hidden="true"></div>
        <h2 id="aiBusyTitle" class="h5 text-white">KI arbeitet</h2>
        <p id="aiBusyMessage" class="mb-3">Bitte warten.</p>
        <button type="button" class="btn btn-outline-light" id="aiCancelButton">
            <i class="bi bi-x-lg me-1"></i>Abbrechen
        </button>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const overlay = document.getElementById('aiBusyOverlay');
            const title = document.getElementById('aiBusyTitle');
            const message = document.getElementById('aiBusyMessage');
            const cancelButton = document.getElementById('aiCancelButton');
            const pageContent = document.getElementById('aiPageContent');
            let activeAiRequest = null;
            let transientErrorAlert = document.querySelector('[data-transient-error-alert]');

            const dismissTransientError = () => {
                transientErrorAlert?.remove();
                transientErrorAlert = null;
            };

            const showBusyOverlay = (form) => {
                dismissTransientError();
                title.textContent = form.dataset.aiBusyTitle || 'KI arbeitet';
                message.textContent = form.dataset.aiBusyMessage || 'Bitte warten.';
                cancelButton.innerHTML = '<i class="bi bi-x-lg me-1"></i>Abbrechen';
                overlay.classList.remove('d-none');
                overlay.classList.add('d-flex');
                pageContent?.setAttribute('inert', '');
                document.body.style.overflow = 'hidden';
                document.body.setAttribute('aria-busy', 'true');

                form.querySelectorAll('button').forEach((button) => {
                    button.disabled = true;
                });

                cancelButton.focus();
            };

            const hideBusyOverlay = (form) => {
                overlay.classList.add('d-none');
                overlay.classList.remove('d-flex');
                pageContent?.removeAttribute('inert');
                document.body.style.overflow = '';
                document.body.removeAttribute('aria-busy');

                form?.querySelectorAll('button').forEach((button) => {
                    button.disabled = false;
                });

                if (!form) {
                    document.querySelectorAll('form[data-ai-busy-form] button').forEach((button) => {
                        button.disabled = false;
                    });
                }
            };

            document.querySelectorAll('form[data-ai-busy-form]').forEach((form) => {
                form.addEventListener('submit', async (event) => {
                    event.preventDefault();

                    if (activeAiRequest) {
                        return;
                    }

                    const abortController = new AbortController();
                    activeAiRequest = { abortController, form };
                    showBusyOverlay(form);

                    try {
                        const response = await fetch(form.action, {
                            method: form.method || 'post',
                            body: new FormData(form),
                            signal: abortController.signal,
                            credentials: 'same-origin'
                        });

                        if (abortController.signal.aborted) {
                            return;
                        }

                        if (!response.ok) {
                            throw new Error('AI request failed.');
                        }

                        if (response.redirected) {
                            window.location.assign(response.url);
                            return;
                        }

                        const html = await response.text();
                        document.open();
                        document.write(html);
                        document.close();
                    } catch (error) {
                        if (error.name !== 'AbortError') {
                            message.textContent = 'Es ist ein Fehler aufgetreten, bitte versuche es erneut.';
                            cancelButton.textContent = 'Schließen';
                            return;
                        }

                        hideBusyOverlay(form);
                    } finally {
                        if (activeAiRequest?.abortController === abortController) {
                            activeAiRequest = null;
                        }
                    }
                });
            });

            cancelButton.addEventListener('click', () => {
                if (activeAiRequest) {
                    activeAiRequest.abortController.abort();
                    hideBusyOverlay(activeAiRequest.form);
                    activeAiRequest = null;
                    cancelButton.innerHTML = '<i class="bi bi-x-lg me-1"></i>Abbrechen';
                } else {
                    hideBusyOverlay();
                    cancelButton.innerHTML = '<i class="bi bi-x-lg me-1"></i>Abbrechen';
                }
            });

            overlay.addEventListener('keydown', (event) => {
                if (event.key === 'Escape' && activeAiRequest) {
                    activeAiRequest.abortController.abort();
                    hideBusyOverlay(activeAiRequest.form);
                    activeAiRequest = null;
                }
            });

            document.addEventListener('click', (event) => {
                if (!event.target.closest('[data-transient-error-alert]')) {
                    dismissTransientError();
                }
            });

            document.addEventListener('submit', () => {
                dismissTransientError();
            });

            const proposalModalElement = document.getElementById('aiProposalModal');
            if (proposalModalElement) {
                new bootstrap.Modal(proposalModalElement).show();
            }

            const reviewModalElement = document.getElementById('aiReviewModal-@autoOpenReviewQuestionId');
            if (reviewModalElement) {
                new bootstrap.Modal(reviewModalElement).show();
            }
        })();
    </script>
}
