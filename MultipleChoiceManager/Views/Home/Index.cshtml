@{
    ViewData["Title"] = "Home";
    Layout = "_LandingLayout";
}

<section class="landing-hero">
    <div class="container">
        <div class="landing-hero-panel text-center">
            <span class="mc-eyebrow mb-3 d-inline-block">
                <i class="bi bi-mortarboard me-1"></i>Für Lehrstühle &amp; Dozierende
            </span>
            <h1 class="mb-3">
                Multiple-Choice-Klausuren<br class="d-none d-md-inline" />
                einfach verwalten
            </h1>
            <div class="col-lg-8 mx-auto">
                <p class="lead mb-4">
                    Der Multiple-Choice-Manager unterstützt Lehrstühle bei der Erstellung von
                    Multiple-Choice-Klausuren: Lehrveranstaltungen mit Kapiteln und Vorlesungsfolien
                    verwalten, Fragenkataloge pflegen und daraus per Zufall Prüfungen zusammenstellen –
                    mit KI-Unterstützung für neue und bestehende Fragen.
                </p>
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a class="btn btn-primary btn-lg" asp-route="app">
                        <i class="bi bi-box-arrow-in-right me-2"></i>App öffnen
                    </a>
                    <a class="btn btn-outline-secondary btn-lg" href="#features">
                        Mehr erfahren
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <span class="mc-eyebrow mb-2 d-inline-block">Funktionen</span>
            <h2 class="mb-3">Alles für die Klausurerstellung an einem Ort</h2>
            <p class="lead col-lg-7 mx-auto mb-0">
                Vom Vorlesungsmaterial bis zur fertigen Prüfung – der MC-Manager begleitet den
                gesamten Ablauf.
            </p>
        </div>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <div class="col">
                <div class="landing-feature-card">
                    <div class="card-body">
                        <div class="landing-feature-icon">
                            <i class="bi bi-mortarboard"></i>
                        </div>
                        <h5 class="mb-2">Lehrveranstaltungen &amp; Kapitel</h5>
                        <p class="text-body-secondary mb-0">
                            Strukturiere Lehrveranstaltungen in Kapitel und behalte
                            jederzeit den Überblick.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="landing-feature-card">
                    <div class="card-body">
                        <div class="landing-feature-icon">
                            <i class="bi bi-file-earmark-pdf"></i>
                        </div>
                        <h5 class="mb-2">Vorlesungsfolien</h5>
                        <p class="text-body-secondary mb-0">
                            Lade je Kapitel die passenden Folien als PDF hoch – sicher
                            abgelegt und jederzeit abrufbar.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="landing-feature-card">
                    <div class="card-body">
                        <div class="landing-feature-icon">
                            <i class="bi bi-patch-question"></i>
                        </div>
                        <h5 class="mb-2">Fragenkatalog</h5>
                        <p class="text-body-secondary mb-0">
                            Pflege pro Kapitel Multiple-Choice-Fragen mit 4
                            Antwortoptionen und Markierung der richtigen Antworten.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="landing-feature-card">
                    <div class="card-body">
                        <div class="landing-feature-icon">
                            <i class="bi bi-shuffle"></i>
                        </div>
                        <h5 class="mb-2">Prüfungen per Zufall</h5>
                        <p class="text-body-secondary mb-0">
                            Stelle aus dem Fragenkatalog per Zufallsauswahl in Sekunden eine
                            neue Klausur zusammen.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="landing-feature-card">
                    <div class="card-body">
                        <div class="landing-feature-icon">
                            <i class="bi bi-stars"></i>
                        </div>
                        <h5 class="mb-2">KI-generierte Fragen</h5>
                        <p class="text-body-secondary mb-0">
                            Lasse aus den hochgeladenen Folien automatisch neue
                            Fragenvorschläge generieren.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="landing-feature-card">
                    <div class="card-body">
                        <div class="landing-feature-icon">
                            <i class="bi bi-check2-circle"></i>
                        </div>
                        <h5 class="mb-2">Qualitätsprüfung</h5>
                        <p class="text-body-secondary mb-0">
                            Bestehende Fragen werden mit KI auf sprachliche Korrektheit und
                            Eindeutigkeit geprüft.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="ablauf" class="landing-steps py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <span class="mc-eyebrow mb-2 d-inline-block">Ablauf</span>
            <h2 class="mb-3">So funktioniert's</h2>
            <p class="lead mb-0">In drei Schritten zur fertigen Klausur.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4 text-center">
                <div class="landing-step-circle mx-auto">1</div>
                <h5 class="mb-2">Struktur anlegen</h5>
                <p class="text-body-secondary">
                    Lehrveranstaltung erstellen, in Kapitel gliedern und die Vorlesungsfolien als
                    PDF hochladen.
                </p>
            </div>
            <div class="col-md-4 text-center">
                <div class="landing-step-circle mx-auto">2</div>
                <h5 class="mb-2">Fragen pflegen</h5>
                <p class="text-body-secondary">
                    Fragen samt Antwortoptionen selbst erfassen oder mit KI-Unterstützung direkt
                    aus den Folien generieren lassen.
                </p>
            </div>
            <div class="col-md-4 text-center">
                <div class="landing-step-circle mx-auto">3</div>
                <h5 class="mb-2">Prüfung erstellen</h5>
                <p class="text-body-secondary">
                    Per Zufallsauswahl eine Klausur aus dem Fragenkatalog zusammenstellen – fertig.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container py-4">
        <div class="landing-cta text-center">
            <h2 class="mb-3">Bereit loszulegen?</h2>
            <p class="lead mb-4 col-lg-7 mx-auto">
                Starte jetzt mit deiner ersten Lehrveranstaltung und baue deinen
                Fragenkatalog auf.
            </p>
            <a class="btn btn-light btn-lg" asp-route="app">
                <i class="bi bi-box-arrow-in-right me-2"></i>App öffnen
            </a>
        </div>
    </div>
</section>