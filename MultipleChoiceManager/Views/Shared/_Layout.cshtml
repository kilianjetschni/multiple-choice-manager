@{
    var currentController = ViewContext.RouteData.Values["controller"] as string;
    // Kapitel und Fragen sind nur über die Lehrveranstaltungen erreichbar,
    // daher bleibt der Tab dort aktiv.
    var isCoursesActive = string.Equals(currentController, "Courses", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Chapters", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Questions", StringComparison.OrdinalIgnoreCase);
    var isExamsActive = string.Equals(currentController, "Exams", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MultipleChoiceManager</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MultipleChoiceManager.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex flex-column flex-md-row app-shell">
        <nav class="sidebar d-flex flex-md-column flex-row align-items-center align-items-md-stretch p-3 bg-dark d-print-none" aria-label="Hauptnavigation">
            <a class="d-flex align-items-center text-white text-decoration-none me-4 me-md-0 mb-md-4"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-card-checklist fs-4 me-2"></i>
                <span class="fs-5 fw-semibold">MC-Manager</span>
            </a>
            <ul class="nav nav-pills flex-md-column flex-row mb-auto">
                <li class="nav-item">
                    <a class="nav-link @(isCoursesActive ? "active" : "text-white")" asp-controller="Courses" asp-action="Index">
                        <i class="bi bi-mortarboard me-2"></i>Lehrveranstaltungen
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(isExamsActive ? "active" : "text-white")" asp-controller="Exams" asp-action="Index">
                        <i class="bi bi-journal-check me-2"></i>Prüfungen
                    </a>
                </li>
            </ul>
        </nav>
        <main role="main" class="flex-grow-1 p-4">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
