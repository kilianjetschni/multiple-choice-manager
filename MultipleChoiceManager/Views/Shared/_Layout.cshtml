@{
    var currentController = ViewContext.RouteData.Values["controller"] as string;
    // Kapitel und Fragen sind nur über die Lehrveranstaltungen erreichbar,
    // daher bleibt der Tab dort aktiv.
    var isCoursesActive = string.Equals(currentController, "Courses", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Chapters", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentController, "Questions", StringComparison.OrdinalIgnoreCase);
    var isExamsActive = string.Equals(currentController, "Exams", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MultipleChoiceManager</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MultipleChoiceManager.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="app-topbar d-lg-none d-print-none px-3 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-topbar" type="button"
                        data-bs-toggle="offcanvas" data-bs-target="#mcSidebarOffcanvas"
                        aria-controls="mcSidebarOffcanvas" aria-label="Navigation öffnen">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <a class="app-topbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span class="mc-brand-mark">MC</span>
                    <span>MC-Manager</span>
                </a>
            </div>
        </header>

        <div class="app-shell-inner">
            <nav class="sidebar sidebar-desktop d-none d-lg-flex d-print-none" aria-label="Hauptnavigation">
                <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                    <span class="mc-brand-mark">MC</span>
                    <span>MC-Manager</span>
                </a>
                <div class="sidebar-section-label">Bereich</div>
                <ul class="nav nav-pills flex-column mb-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link @(isCoursesActive ? "active" : null)"
                           asp-controller="Courses" asp-action="Index">
                            <i class="bi bi-mortarboard"></i>Lehrveranstaltungen
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(isExamsActive ? "active" : null)"
                           asp-controller="Exams" asp-action="Index">
                            <i class="bi bi-journal-check"></i>Prüfungen
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="offcanvas offcanvas-start mc-offcanvas-sidebar d-lg-none"
                 tabindex="-1" id="mcSidebarOffcanvas" aria-labelledby="mcSidebarOffcanvasLabel">
                <div class="offcanvas-header pb-0">
                    <a class="sidebar-brand p-0" asp-controller="Home" asp-action="Index" id="mcSidebarOffcanvasLabel">
                        <span class="mc-brand-mark">MC</span>
                        <span>MC-Manager</span>
                    </a>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Schließen"></button>
                </div>
                <div class="offcanvas-body pt-2 sidebar">
                    <div class="sidebar-section-label px-0">Bereich</div>
                    <ul class="nav nav-pills flex-column mb-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link @(isCoursesActive ? "active" : null)"
                               asp-controller="Courses" asp-action="Index">
                                <i class="bi bi-mortarboard"></i>Lehrveranstaltungen
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(isExamsActive ? "active" : null)"
                               asp-controller="Exams" asp-action="Index">
                                <i class="bi bi-journal-check"></i>Prüfungen
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <main role="main" class="app-content">
                <div class="app-content-inner">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>