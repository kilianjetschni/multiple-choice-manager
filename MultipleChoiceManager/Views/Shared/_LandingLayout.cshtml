<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MultipleChoiceManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MultipleChoiceManager.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand landing-navbar sticky-top" aria-label="Hauptnavigation">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center fw-semibold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-card-checklist fs-4 me-2 text-primary"></i>
                MC-Manager
            </a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <a class="nav-link d-none d-sm-inline text-body-secondary" href="#features">Funktionen</a>
                <a class="nav-link d-none d-sm-inline text-body-secondary" href="#ablauf">So funktioniert's</a>
                <a class="btn btn-primary px-4" asp-route="app">
                    <i class="bi bi-box-arrow-in-right me-2"></i>App
                </a>
            </div>
        </div>
    </nav>
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>
    <footer class="landing-footer border-top py-4 mt-auto">
        <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
            <span class="text-body-secondary">
                <i class="bi bi-card-checklist me-1"></i>MC-Manager &middot; Web Engineering
            </span>
            <div class="d-flex gap-3">
                <a class="text-body-secondary text-decoration-none" asp-route="app">App</a>
                <a class="text-body-secondary text-decoration-none" asp-controller="Home" asp-action="Privacy">Datenschutz</a>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
