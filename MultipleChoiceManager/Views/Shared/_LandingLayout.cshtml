<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MultipleChoiceManager</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MultipleChoiceManager.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand landing-navbar sticky-top" aria-label="Hauptnavigation">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <span class="mc-brand-mark">MC</span>
                <span>MC-Manager</span>
            </a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <a class="nav-link d-none d-sm-inline" href="#features">Funktionen</a>
                <a class="nav-link d-none d-sm-inline" href="#ablauf">So funktioniert's</a>
                <a class="btn btn-primary" asp-route="app">
                    <i class="bi bi-box-arrow-in-right me-2"></i>App öffnen
                </a>
            </div>
        </div>
    </nav>
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>
    <footer class="landing-footer py-4 mt-auto">
        <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
            <span>
                <span class="mc-brand-mark me-2" style="width:1.5rem;height:1.5rem;font-size:.7rem;">MC</span>
                MC-Manager &middot; Web Engineering
            </span>
            <div class="d-flex gap-3">
                <a asp-route="app">App</a>
                <a asp-controller="Home" asp-action="Privacy">Datenschutz</a>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>